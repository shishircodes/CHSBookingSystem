PORT=5000
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed frontend origins. In production set this to
# your Vercel frontend URL (e.g. https://chs-frontend.vercel.app).
CORS_ORIGIN=http://localhost:5173
# Local-only: set "true" if you're testing https locally. In production on
# Vercel, NODE_ENV=production automatically enables Secure + SameSite=None.
COOKIE_SECURE=false
